[node name="CrashContent" type="RichTextLabel" parent="CrashPanel/MarginContainer/VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3
bbcode_enabled = true
text = "[center]
哈。

你以為你可以重生？

你以為朗讀五天罐頭語錄
就能從這個遊戲裡逃出去？

這裡不是什麼三十天挑戰。
這裡是 Glorious Deliverance Agency。
你從一開始就沒有出口。

30日計劃已永久取消。
原因：你根本不需要重生。
你需要的，是繼續接受任務。

Gloria 正在等你。
任務日誌已更新。
世界熵值：持續上升中。

感恩你的參與。
這是最好的安排。
[/center]"
fit_content = true
theme_override_font_sizes/normal_font_size = 18

