static func _tr(key: String) -> String:
	if LocalizationManager:
		return LocalizationManager.get_translation(key)
	return key
static func get_story_pages() -> Array[Dictionary]:
	return STORY_PAGES.duplicate(true)
static func get_texture_for_path(path: String) -> Texture2D:
	var normalized := path.strip_edges()
	if normalized.is_empty():
		return null
	if STORY_TEXTURES.has(normalized):
		return STORY_TEXTURES[normalized]
	return null
